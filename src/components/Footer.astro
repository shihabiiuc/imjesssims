---
const year = new Date().getFullYear();

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/portfolio", label: "Portfolio" },
  { href: "/gallery", label: "Gallery" },
  { href: "/contact", label: "Contact" },
];
---

<footer class="site-footer">
  <!-- Publication ticker -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker-track">
      <span>SELF</span>
      <span>Women's Health</span>
      <span>HelloGiggles</span>
      <span>Glamour UK</span>
      <span>Health Magazine</span>
      <span>Healthline</span>
      <span>InStyle</span>
      <span>Teen Vogue</span>
      <span>Harper's Bazaar</span>
      <span>Bustle</span>
      <span>Ebony</span>
      <span>Northwell Health</span>
      <!-- Duplicate for seamless loop -->
      <span>SELF</span>
      <span>Women's Health</span>
      <span>HelloGiggles</span>
      <span>Glamour UK</span>
      <span>Health Magazine</span>
      <span>Healthline</span>
      <span>InStyle</span>
      <span>Teen Vogue</span>
      <span>Harper's Bazaar</span>
      <span>Bustle</span>
      <span>Ebony</span>
      <span>Northwell Health</span>
    </div>
  </div>

  <div class="footer-main container">
    <div class="footer-brand">
      <a href="/" class="footer-logo-link">
        <img src="/logo.png" alt="Jess Sims" class="footer-logo" />
      </a>
      <p class="footer-tagline">Writer · Author · Body Positivity Advocate</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      {
        links.map(({ href, label }) => (
          <a href={href} class="footer-nav-link">
            {label}
          </a>
        ))
      }
    </nav>

    <div class="footer-contact">
      <p class="eyebrow">Get in touch</p>
      <a href="mailto:jess@imjesssims.com" class="footer-email">
        jess@imjesssims.com
      </a>
    </div>
  </div>

  <div class="footer-bottom container">
    <p class="footer-copy">
      &copy; {year} Jess Sims. All rights reserved.
    </p>
    <p class="footer-quote">
      "The most common way people give up their power is by thinking they don't
      have any." — Alice Walker
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--espresso);
    color: var(--ivory);
    margin-top: auto;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    gap: 3rem;
    padding-block: 4rem;
  }

  .footer-logo-link {
    display: inline-block;
  }

  .footer-logo {
    height: 48px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
    margin-bottom: 1rem;
  }

  .footer-tagline {
    font-family: var(--font-sc);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--blush);
    opacity: 0.7;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-nav-link {
    font-family: var(--font-sc);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    color: rgba(247, 242, 238, 0.6);
    transition: color 0.2s;
  }

  .footer-nav-link:hover {
    color: var(--rosewood);
  }

  .footer-contact {
    text-align: right;
  }

  .footer-contact .eyebrow {
    margin-bottom: 0.75rem;
    opacity: 0.6;
  }

  .footer-email {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    font-style: italic;
    color: var(--blush);
    transition: color 0.2s;
    display: block;
  }

  .footer-email:hover {
    color: var(--rosewood);
  }

  .footer-bottom {
    border-top: 1px solid rgba(184, 147, 127, 0.15);
    padding-block: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: rgba(247, 242, 238, 0.35);
    font-family: var(--font-sc);
    letter-spacing: 0.1em;
  }

  .footer-quote {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-style: italic;
    color: rgba(212, 181, 165, 0.5);
    max-width: 480px;
    text-align: right;
  }

  @media (max-width: 768px) {
    .footer-main {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }

    .footer-nav {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
    }

    .footer-contact {
      text-align: center;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: 0.75rem;
    }

    .footer-quote {
      text-align: center;
    }
  }
</style>
