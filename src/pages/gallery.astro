---
import Layout from "../layouts/Layout.astro";

import g1 from "../assets/gallery/137069597_1298068633898669_6395820760268769084_n.jpg";
import g2 from "../assets/gallery/173176212_1363881200650745_5892447380394473728_n.jpg";
import g3 from "../assets/gallery/178362286_1371610129877852_8128462508646759319_n.jpg";
import g4 from "../assets/gallery/178412360_1371610136544518_2961280763871025039_n.jpg";
import g5 from "../assets/gallery/469294558_1326518268454588_3675796619853957706_n.jpg";
import g6 from "../assets/gallery/472558942_1349990766107338_2999974061131095624_n.jpg";
import g7 from "../assets/gallery/473084668_1353961019043646_22272416558277501_n.jpg";
import g8 from "../assets/gallery/473317998_1353960989043649_1908157630499703629_n.jpg";
import g9 from "../assets/gallery/473570238_1353960832376998_3329072643647841708_n.jpg";
import g10 from "../assets/gallery/473582637_1355103265596088_1748709571635805320_n.jpg";
import g11 from "../assets/gallery/473594351_1355103538929394_1889306308120207134_n.jpg";

const images = [g1, g2, g3, g4, g5, g6, g7, g8, g9, g10, g11];
---

<Layout title="Gallery — Jess Sims">
  <!-- Hero -->
  <section class="gal-hero">
    <div class="gal-hero__eyebrow">Behind the Lens</div>
    <h1 class="gal-hero__title">Gallery</h1>
    <p class="gal-hero__sub">
      A visual diary — moments, style, and life in motion.
    </p>
  </section>

  <!-- Masonry Grid -->
  <section class="gal-grid-wrap">
    <div class="gal-grid" id="gallery-grid">
      {
        images.map((img, i) => (
          <div class="gal-grid__item">
            <button
              class="gal-grid__btn"
              aria-label={`Open image ${i + 1}`}
              data-src={img.src}
              data-index={i}
            >
              <img
                src={img.src}
                alt={`Gallery image ${i + 1}`}
                class="gal-grid__img"
                loading={i < 4 ? "eager" : "lazy"}
                decoding="async"
              />
              <div class="gal-grid__overlay">
                <span class="gal-grid__zoom">+</span>
              </div>
            </button>
          </div>
        ))
      }
    </div>
  </section>
</Layout>

<script>
  // ── Lightbox singleton ──────────────────────────────────────────────────────
  // We create ONE lightbox element and append it directly to <body>.
  // This keeps it completely outside any view-transition stacking context,
  // which is what causes position:fixed to break and the page to scroll down.

  function ensureLightbox() {
    let lb = document.getElementById("glb") as HTMLElement | null;
    if (lb) return lb;

    lb = document.createElement("div");
    lb.id = "glb";
    lb.setAttribute("role", "dialog");
    lb.setAttribute("aria-modal", "true");
    lb.setAttribute("aria-label", "Image viewer");
    lb.setAttribute("aria-hidden", "true");
    lb.innerHTML = `
      <button id="glb-close" aria-label="Close lightbox">✕</button>
      <button id="glb-prev"  aria-label="Previous image">‹</button>
      <button id="glb-next"  aria-label="Next image">›</button>
      <div id="glb-stage"><img id="glb-img" src="" alt="" /></div>
      <div id="glb-counter"></div>
    `;
    document.body.appendChild(lb);
    return lb;
  }

  // ── State ───────────────────────────────────────────────────────────────────
  let current = 0;
  let srcs: string[] = [];
  let btns: HTMLButtonElement[] = [];
  let cleanupKeydown: (() => void) | null = null;

  // ── Helpers ─────────────────────────────────────────────────────────────────
  function openLightbox(index: number) {
    current = index;
    const lb = document.getElementById("glb")!;
    const img = document.getElementById("glb-img") as HTMLImageElement;
    const counter = document.getElementById("glb-counter")!;

    img.src = srcs[current];
    img.alt = `Gallery image ${current + 1}`;
    counter.textContent = `${current + 1} / ${srcs.length}`;

    lb.classList.add("glb--open");
    lb.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";

    requestAnimationFrame(() => {
      document.getElementById("glb-close")?.focus();
    });
  }

  function closeLightbox() {
    const lb = document.getElementById("glb")!;
    lb.classList.remove("glb--open");
    lb.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    btns[current]?.focus();
  }

  function showPrev() {
    openLightbox((current - 1 + srcs.length) % srcs.length);
  }

  function showNext() {
    openLightbox((current + 1) % srcs.length);
  }

  // ── Init (runs on every page-load) ─────────────────────────────────────────
  function init() {
    const lb = ensureLightbox();

    // Re-query buttons for this page
    btns = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".gal-grid__btn"),
    );
    if (btns.length === 0) return;

    srcs = btns.map((b) => b.dataset.src!);

    // Attach gallery button listeners
    btns.forEach((btn, i) =>
      btn.addEventListener("click", () => openLightbox(i)),
    );

    // Lightbox click delegation
    lb.addEventListener("click", (e) => {
      const t = e.target as HTMLElement;
      const id = t.id || t.closest("button")?.id;
      if (id === "glb-close" || t === lb) {
        closeLightbox();
        return;
      }
      if (id === "glb-prev") {
        showPrev();
        return;
      }
      if (id === "glb-next") {
        showNext();
        return;
      }
    });

    // Keyboard — tear down old listener before adding new one
    if (cleanupKeydown) cleanupKeydown();
    const onKeydown = (e: KeyboardEvent) => {
      const lb = document.getElementById("glb");
      if (!lb?.classList.contains("glb--open")) return;
      if (e.key === "Escape") {
        e.preventDefault();
        closeLightbox();
      }
      if (e.key === "ArrowLeft") {
        e.preventDefault();
        showPrev();
      }
      if (e.key === "ArrowRight") {
        e.preventDefault();
        showNext();
      }
    };
    document.addEventListener("keydown", onKeydown);
    cleanupKeydown = () => document.removeEventListener("keydown", onKeydown);

    // ── Scroll-reveal ─────────────────────────────────────────────────────────
    const items = document.querySelectorAll<HTMLElement>(".gal-grid__item");

    // Reset first — critical for re-navigation
    items.forEach((el, i) => {
      el.style.transition = "none";
      el.style.opacity = "0";
      el.style.transform = "translateY(24px)";
      // Force reflow so the reset is painted before we re-enable transitions
      el.getBoundingClientRect();
      el.style.transition = `opacity 0.6s ease ${i * 60}ms, transform 0.6s ease ${i * 60}ms`;
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.style.opacity = "1";
            el.style.transform = "translateY(0)";
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.05, rootMargin: "0px 0px -40px 0px" },
    );

    items.forEach((el) => observer.observe(el));
  }

  // Cleanup lightbox state before the DOM is swapped out
  document.addEventListener("astro:before-swap", () => {
    document.body.style.overflow = "";
    const lb = document.getElementById("glb");
    lb?.classList.remove("glb--open");
    lb?.setAttribute("aria-hidden", "true");
  });

  document.addEventListener("astro:page-load", init);
</script>

<style is:global>
  /* ── Lightbox (global — lives on <body>, outside Layout) ── */
  #glb {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(10, 7, 5, 0.96);
    align-items: center;
    justify-content: center;
    /* Explicitly neutralise any inherited transform / will-change */
    transform: none !important;
    will-change: auto !important;
  }

  #glb.glb--open {
    display: flex;
  }

  #glb-stage {
    max-width: 90vw;
    max-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #glb-img {
    max-width: 100%;
    max-height: 88vh;
    object-fit: contain;
    display: block;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
    border-radius: 2px;
  }

  #glb-close {
    position: fixed;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: 1px solid rgba(212, 181, 165, 0.2);
    border-radius: 50%;
    color: var(--blush, #d4b5a5);
    font-size: 1.25rem;
    cursor: pointer;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      color 0.2s,
      transform 0.2s,
      border-color 0.2s;
    z-index: 10000;
    line-height: 1;
  }

  #glb-close:hover {
    color: var(--ivory, #f5f0ea);
    border-color: rgba(212, 181, 165, 0.6);
    transform: rotate(90deg);
  }

  #glb-prev,
  #glb-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--blush, #d4b5a5);
    font-size: 3.5rem;
    cursor: pointer;
    padding: 1rem;
    transition:
      color 0.2s,
      transform 0.2s;
    font-family: "Cormorant Garamond", serif;
    line-height: 1;
    z-index: 10000;
  }

  #glb-prev {
    left: 1rem;
  }
  #glb-next {
    right: 1rem;
  }

  #glb-prev:hover {
    color: var(--ivory, #f5f0ea);
    transform: translateY(-50%) translateX(-4px);
  }
  #glb-next:hover {
    color: var(--ivory, #f5f0ea);
    transform: translateY(-50%) translateX(4px);
  }

  #glb-counter {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: "Cormorant SC", serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--rosewood, #b8937f);
  }
</style>

<style>
  /* ─── Hero ─── */
  .gal-hero {
    padding: clamp(7rem, 14vw, 12rem) clamp(1.5rem, 8vw, 8rem)
      clamp(4rem, 6vw, 6rem);
    background: var(--espresso);
    position: relative;
    overflow: hidden;
  }

  .gal-hero::after {
    content: "✦";
    position: absolute;
    bottom: -2rem;
    right: clamp(1.5rem, 8vw, 8rem);
    font-size: clamp(8rem, 22vw, 22rem);
    color: rgba(184, 147, 127, 0.06);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .gal-hero__eyebrow {
    font-family: "Cormorant SC", serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--rosewood);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .gal-hero__title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(4rem, 12vw, 11rem);
    font-weight: 300;
    color: var(--blush);
    margin: 0 0 1.5rem;
    letter-spacing: -0.03em;
    line-height: 0.9;
  }

  .gal-hero__sub {
    font-family: "Inter", sans-serif;
    font-size: 1rem;
    color: rgba(212, 181, 165, 0.7);
    margin: 0;
    max-width: 35ch;
  }

  /* ─── Grid ─── */
  .gal-grid-wrap {
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 6vw, 6rem);
    background: var(--ivory);
  }

  .gal-grid {
    columns: 3;
    column-gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .gal-grid {
      columns: 2;
    }
  }
  @media (max-width: 500px) {
    .gal-grid {
      columns: 1;
    }
  }

  .gal-grid__item {
    break-inside: avoid;
    margin-bottom: 1.25rem;
    /* Start hidden — JS will reset & animate */
    opacity: 0;
    transform: translateY(24px);
  }

  .gal-grid__btn {
    display: block;
    width: 100%;
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .gal-grid__img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.5s ease;
  }

  .gal-grid__overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 20, 16, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.35s;
  }

  .gal-grid__zoom {
    font-family: "Cormorant Garamond", serif;
    font-size: 2.5rem;
    color: var(--ivory);
    opacity: 0;
    transition:
      opacity 0.3s,
      transform 0.3s;
    transform: scale(0.8);
  }

  .gal-grid__btn:hover .gal-grid__img {
    transform: scale(1.04);
  }
  .gal-grid__btn:hover .gal-grid__overlay {
    background: rgba(26, 20, 16, 0.45);
  }
  .gal-grid__btn:hover .gal-grid__zoom {
    opacity: 1;
    transform: scale(1);
  }

  /* ─── View Transitions ─── */
  ::view-transition-old(root) {
    animation: 300ms ease-in both gal-fade-out;
  }
  ::view-transition-new(root) {
    animation: 400ms ease-out both gal-fade-in;
  }

  @keyframes gal-fade-out {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }
  @keyframes gal-fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
