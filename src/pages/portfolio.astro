---
import Layout from "../layouts/Layout.astro";

const clips = [
  {
    category: "Women's & Reproductive Health + Femtech",
    items: [
      {
        pub: "The Well by Northwell Health",
        title: "The Science Behind Cold Meds During Pregnancy",
        href: "https://thewell.northwell.edu/pregnancy/what-can-i-take-for-a-cold-while-pregnant",
      },
      {
        pub: "SELF",
        title: "3 Signs Your Doctor Isn't Taking Your Heart Health Seriously",
        href: "https://www.self.com/story/cardiologist-red-flags",
      },
      {
        pub: "The Well by Northwell",
        title: "Understanding The Risks Of Skin Picking",
        href: "https://thewell.northwell.edu/skin-health/skin-picking-disorder",
      },
      {
        pub: "Health Magazine",
        title:
          "Simone Biles Is Redefining What Strength Means as a Black Woman",
        href: "https://www.dropbox.com/home/Portfolio%20to%20share?di=left_nav_browse&preview=Health_Simone+Biles+Is+Redefining+What+Strength+Means+as+a+Black+WomanHeres+Why+Thats+So+Important+to+Me.pdf",
      },
      {
        pub: "Healthline",
        title:
          "Dear Fat, Black Girls Who Were Not Spared from Diet Culture—I Understand",
        href: "https://www.healthline.com/health/diet-culture-affects-fat-black-women",
      },
    ],
  },
  {
    category: "Lifestyle",
    items: [
      {
        pub: "Ebony",
        title:
          "Everything to Know About Seeing Beyoncé and Other Artists on Their International Tour Stops",
        href: "#",
      },
      {
        pub: "My San Antonio",
        title:
          "This Martin Luther King Jr. Day, Black Leaders Reflect on What's Next for SA",
        href: "https://www.mysanantonio.com/lifestyle/slideshow/san-antonio-Reflecting-on-legacy-of-MLK-215745.php",
      },
      {
        pub: "Openly",
        title: "Can the Barbie Movie Finally Give Us the Gay Ken We Deserve?",
        href: "https://www.openlynews.com/i/?id=0a74d50c-b9e7-4bb7-a37c-17ff0a8e1067",
      },
    ],
  },
  {
    category: "Fashion, Beauty & Culture",
    items: [
      {
        pub: "Glamour UK",
        title:
          "Tina Turner Pulled Off the 'Greatest Second Act' in Entertainment History",
        href: "https://www.glamourmagazine.co.uk/article/tina-turner-legacy",
      },
      {
        pub: "Bustle",
        title: "Let's Be More Like Angel Reese",
        href: "https://www.bustle.com/rule-breakers/angel-reese-unpaid-labor-required-of-black-women-athletes",
      },
      {
        pub: "LGBTQ Nation",
        title:
          "Queer Black People Invented House Music: The Remarkable History of the Beloved Genre",
        href: "#",
      },
      {
        pub: "InStyle",
        title:
          "The Best Plus-Size Loungewear Brands That Every Curvy Babe Should Know About",
        href: "#",
      },
      {
        pub: "InStyle",
        title:
          "5 Plus-Size Influencers Share Their Complicated Journeys to Finding Their Personal Style",
        href: "https://www.instyle.com/fashion/clothing/plus-size-influencers-personal-style",
      },
      {
        pub: "SheKnows",
        title:
          "Can't Turn Around Now, We've Come This Far: The Story of Juneteenth, Texas & My Family",
        href: "https://www.sheknows.com/entertainment/articles/2275750/juneteenth-family-history/",
      },
      {
        pub: "InStyle",
        title:
          "The Five Best Plus Size Activewear Brands That Are Truly Size-Inclusive",
        href: "https://finance.yahoo.com/news/5-plus-size-activewear-brands-160000228.html",
      },
    ],
  },
];

const credits = [
  "SELF",
  "Health",
  "Glamour UK",
  "HelloGiggles",
  "Women's Health",
  "Vox",
  "Meredith",
  "Condé Nast",
  "Northwell Health",
  "Maven Clinic",
  "Needed",
  "Allara Health",
  "Gilead Sciences",
  "Bristol Myers Squibb",
  "NBC Universal",
  "Ebony",
  "InStyle",
  "Bustle",
  "Healthline",
  "SheKnows",
];

const services = [
  { icon: "📚", label: "Educates & informs your audience" },
  { icon: "🗣️", label: "Explains your products & services" },
  { icon: "❤️", label: "Shares your mission & values" },
];

const deliverables = [
  "SEO Strategy",
  "Blog Posts",
  "Web Copy",
  "White Papers",
  "Sales Emails",
  "Brand Messaging",
];
---

<Layout title="Portfolio — Jess Sims">
  <!-- Hero -->
  <section class="port-hero">
    <div class="port-hero__eyebrow">
      Freelance Writer · Healthcare Copywriter
    </div>
    <h1 class="port-hero__headline">
      Words that <em>work</em> for women's health.
    </h1>
    <p class="port-hero__sub">
      Smart, compelling, results-driven copy — from femtech startups to
      established wellness brands.
    </p>
    <a href="/contact" class="port-hero__cta">Let's work together</a>
  </section>

  <!-- Scrolling Credits Tape -->
  <div class="tape-wrap" aria-label="Publication credits">
    <div class="tape">
      {
        [...credits, ...credits].map((c) => (
          <span class="tape__item">
            {c}
            <span class="tape__dot">✦</span>
          </span>
        ))
      }
    </div>
  </div>

  <!-- About the work -->
  <section class="port-bio">
    <div class="port-bio__inner">
      <div class="port-bio__text">
        <p class="port-bio__lead">
          I'm Jess — a seasoned health and medical copywriting pro with a
          specialty in <strong>women's health, femtech, and wellness.</strong>
        </p>
        <p>
          Published in SELF, Health, Glamour UK, HelloGiggles, and Women's
          Health. Branded content for Vox, Meredith, Condé Nast, Northwell
          Health, and Maven Clinic. Before freelancing, I worked in-house and
          agency-side with global healthcare brands like <strong>Teva</strong> — makers
          of Plan B and Paragard — bringing real-world industry savvy to every word.
        </p>
      </div>
      <div class="port-bio__services">
        <div class="port-bio__services-label">Copy that—</div>
        {
          services.map((s) => (
            <div class="port-bio__service-item">
              <span class="port-bio__service-icon">{s.icon}</span>
              <span>{s.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Deliverables strip -->
  <div class="deliverables-strip">
    {deliverables.map((d) => <span class="deliverables-strip__tag">{d}</span>)}
  </div>

  <!-- Clips -->
  <section class="clips">
    <div class="clips__header">
      <span class="clips__eyebrow">Recent Work</span>
      <h2 class="clips__title">Published Clips</h2>
    </div>

    {
      clips.map((section) => (
        <div class="clips__section">
          <h3 class="clips__cat">{section.category}</h3>
          <ul class="clips__list">
            {section.items.map((item) => (
              <li class="clips__item">
                <a
                  href={item.href}
                  class="clips__link"
                  target="_blank"
                  rel="noopener"
                >
                  <span class="clips__pub">{item.pub}</span>
                  <span class="clips__arrow">→</span>
                  <span class="clips__title-text">{item.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </section>

  <!-- Quote -->
  <section class="port-quote">
    <div class="port-quote__inner">
      <blockquote class="port-quote__text">
        "I think writing really helps you heal yourself. I think if you write
        long enough, you will be a healthy person."
      </blockquote>
      <cite class="port-quote__attr">— Alice Walker</cite>
    </div>
  </section>

  <!-- CTA -->
  <section class="port-cta">
    <h2 class="port-cta__headline">Ready to make magic?</h2>
    <p class="port-cta__sub">
      Present and past clients include Needed, Allara Health, Northwell Health,
      Gilead Sciences, Bristol Myers Squibb, NBC Universal, and more.
    </p>
    <a href="/contact" class="port-cta__btn">Contact Me</a>
    <a href="mailto:jess@imjesssims.com" class="port-cta__email"
      >jess@imjesssims.com</a
    >
  </section>
</Layout>

<style>
  /* ─── Hero ─── */
  .port-hero {
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(6rem, 12vw, 10rem) clamp(1.5rem, 8vw, 8rem);
    background: var(--mahogany);
    position: relative;
    overflow: hidden;
  }

  .port-hero::before {
    content: "";
    position: absolute;
    top: -10%;
    right: -5%;
    width: 55%;
    height: 120%;
    background: linear-gradient(135deg, var(--rosewood) 0%, transparent 60%);
    pointer-events: none;
  }

  .port-hero::after {
    content: "PORTFOLIO";
    position: absolute;
    bottom: 4rem;
    right: clamp(1.5rem, 8vw, 8rem);
    font-family: "Cormorant SC", serif;
    font-size: clamp(2rem, 7vw, 8rem);
    font-weight: 700;
    color: var(--parchment);
    letter-spacing: -0.02em;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }
  @media (min-width: 820px) {
    .port-hero::after {
      font-size: clamp(5rem, 14vw, 16rem);
    }
  }

  .port-hero__eyebrow {
    font-family: "Cormorant SC", serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--rosewood);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .port-hero__headline {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 300;
    line-height: 1;
    color: var(--espresso);
    max-width: 14ch;
    margin: 0 0 2rem;
    letter-spacing: -0.02em;
  }

  .port-hero__headline em {
    font-style: italic;
    color: var(--rosewood);
  }

  .port-hero__sub {
    font-family: "Inter", sans-serif;
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: #dbcbc3;
    max-width: 45ch;
    line-height: 1.7;
    margin: 0 0 3rem;
  }

  .port-hero__cta {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: var(--rosewood);
    color: var(--ivory);
    font-family: "Cormorant SC", serif;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-decoration: none;
    transition:
      background 0.3s,
      transform 0.3s;
    align-self: flex-start;
  }

  .port-hero__cta:hover {
    background: var(--mahogany);
    transform: translateY(-2px);
  }

  /* ─── Tape ─── */
  .tape-wrap {
    overflow: hidden;
    background: var(--rosewood);
    padding: 0.85rem 0;
    white-space: nowrap;
  }

  .tape {
    display: inline-flex;
    animation: tape-scroll 40s linear infinite;
    will-change: transform;
  }

  .tape-wrap:hover .tape {
    animation-play-state: paused;
  }

  @keyframes tape-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .tape__item {
    font-family: "Cormorant SC", serif;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    color: var(--ivory);
    padding: 0 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tape__dot {
    color: var(--blush);
    font-size: 0.5rem;
  }

  /* ─── Bio ─── */
  .port-bio {
    padding: clamp(5rem, 10vw, 9rem) clamp(1.5rem, 8vw, 8rem);
    background: var(--ivory);
  }

  .port-bio__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .port-bio__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .port-bio__lead {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 400;
    line-height: 1.45;
    color: var(--espresso);
    margin: 0 0 1.5rem;
  }

  .port-bio__lead strong {
    color: var(--rosewood);
    font-weight: 600;
  }

  .port-bio__text p:not(.port-bio__lead) {
    font-family: "Inter", sans-serif;
    font-size: 1rem;
    line-height: 1.8;
    color: #4a3830;
  }

  .port-bio__services {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2.5rem;
    background: var(--parchment);
    align-self: start;
    position: relative;
  }

  .port-bio__services::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--rosewood);
  }

  .port-bio__services-label {
    font-family: "Cormorant SC", serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--rosewood);
    margin-bottom: 0.5rem;
  }

  .port-bio__service-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: "Inter", sans-serif;
    font-size: 0.95rem;
    color: var(--espresso);
  }

  .port-bio__service-icon {
    font-size: 1.1rem;
  }

  /* ─── Deliverables strip ─── */
  .deliverables-strip {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 2.5rem clamp(1.5rem, 8vw, 8rem);
    background: var(--espresso);
  }

  .deliverables-strip__tag {
    font-family: "Cormorant SC", serif;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    padding: 0.6rem 1.4rem;
    border: 1px solid var(--rosewood);
    color: var(--blush);
    transition: all 0.3s;
    cursor: default;
  }

  .deliverables-strip__tag:hover {
    background: var(--rosewood);
    color: var(--ivory);
  }

  /* ─── Clips ─── */
  .clips {
    padding: clamp(5rem, 10vw, 9rem) clamp(1.5rem, 8vw, 8rem);
    background: var(--ivory);
  }

  .clips__header {
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .clips__eyebrow {
    font-family: "Cormorant SC", serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--rosewood);
  }

  .clips__title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300;
    color: var(--espresso);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .clips__section {
    margin: 0 auto 4rem auto;
    max-width: 900px;
  }

  .clips__cat {
    font-family: "Cormorant SC", serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--rosewood);
    text-transform: uppercase;
    margin: 0 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--parchment);
  }

  .clips__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .clips__item {
    border-bottom: 1px solid var(--parchment);
  }

  .clips__link {
    display: grid;
    grid-template-columns: auto 1.5rem 1fr;
    align-items: baseline;
    gap: 0.5rem 0.75rem;
    padding: 1.2rem 0;
    text-decoration: none;
    transition: all 0.25s;
  }

  .clips__link:hover {
    padding-left: 0.5rem;
  }

  .clips__link:hover .clips__arrow {
    color: var(--rosewood);
    transform: translateX(4px);
  }

  .clips__link:hover .clips__title-text {
    color: var(--rosewood);
  }

  .clips__pub {
    font-family: "Cormorant SC", serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--rosewood);
    white-space: nowrap;
    min-width: 11ch;
  }

  .clips__arrow {
    font-size: 0.85rem;
    color: var(--blush);
    transition:
      transform 0.25s,
      color 0.25s;
    justify-self: center;
  }

  .clips__title-text {
    font-family: "Inter", sans-serif;
    font-size: 0.95rem;
    color: var(--espresso);
    line-height: 1.4;
    transition: color 0.25s;
  }

  @media (max-width: 600px) {
    .clips__link {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }
    .clips__arrow {
      display: none;
    }
    .clips__pub {
      font-size: 0.7rem;
    }
  }

  /* ─── Quote ─── */
  .port-quote {
    padding: clamp(5rem, 10vw, 9rem) clamp(1.5rem, 8vw, 8rem);
    background: var(--espresso);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .port-quote__inner {
    max-width: 750px;
    text-align: center;
  }

  .port-quote__text {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(1.6rem, 3.5vw, 2.8rem);
    font-weight: 300;
    font-style: italic;
    color: var(--blush);
    line-height: 1.45;
    margin: 0 0 2rem;
  }

  .port-quote__attr {
    font-family: "Cormorant SC", serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--rosewood);
    font-style: normal;
  }

  /* ─── CTA ─── */
  .port-cta {
    padding: clamp(5rem, 10vw, 9rem) clamp(1.5rem, 8vw, 8rem);
    background: var(--parchment);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .port-cta__headline {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 300;
    color: var(--espresso);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .port-cta__sub {
    font-family: "Inter", sans-serif;
    font-size: 0.95rem;
    color: #5a4a42;
    max-width: 55ch;
    line-height: 1.7;
    margin: 0;
  }

  .port-cta__btn {
    display: inline-block;
    padding: 1rem 3rem;
    background: var(--rosewood);
    color: var(--ivory);
    font-family: "Cormorant SC", serif;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-decoration: none;
    transition:
      background 0.3s,
      transform 0.3s;
    margin-top: 0.5rem;
  }

  .port-cta__btn:hover {
    background: var(--mahogany);
    transform: translateY(-2px);
  }

  .port-cta__email {
    font-family: "Inter", sans-serif;
    font-size: 0.85rem;
    color: var(--rosewood);
    text-decoration: none;
    border-bottom: 1px solid var(--blush);
    padding-bottom: 1px;
    transition: color 0.2s;
  }

  .port-cta__email:hover {
    color: var(--mahogany);
  }

  /* ─── View Transition ─── */
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  ::view-transition-old(root) {
    animation: 300ms ease-in both fade-out-vt;
  }
  ::view-transition-new(root) {
    animation: 400ms ease-out both fade-in-vt;
  }

  @keyframes fade-out-vt {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  @keyframes fade-in-vt {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
